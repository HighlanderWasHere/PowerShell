# Move user to new OU
# Specify the source and destination OUs
$Finance = "OU=Finance,DC=contoso,DC=com"
$Accounting = "OU=Accounting,DC=contoso,DC=com"
 
# Get all users from the source OU
$users = Get-ADUser -Filter * -SearchBase $Finance
 
# Move each user to the destination OU
foreach ($user in $users) {
  Move-ADObject -Identity $user.DistinguishedName -TargetPath $Accounting
  Write-Host "Moved user $($user.Name) to $Accounting"
}
